{
  "description": "Odyssey Engine stop hook for autonomous iteration loops",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
